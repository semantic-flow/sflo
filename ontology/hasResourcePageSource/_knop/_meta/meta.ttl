@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasResourcePageSource/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasResourcePageSource" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasResourcePageSource/_knop/_inventory/inventory.ttl> .
