@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/locatesManifestation/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/locatesManifestation" ;
  sflo:hasWorkingKnopInventoryFile <ontology/locatesManifestation/_knop/_inventory/inventory.ttl> .
