@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasKnopAssetBundle/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasKnopAssetBundle" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasKnopAssetBundle/_knop/_inventory/inventory.ttl> .
