@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasKnopSourceRegistry> sflo:hasReferenceLink <ontology/hasKnopSourceRegistry/_knop/_references#reference001> .

<ontology/hasKnopSourceRegistry/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/hasKnopSourceRegistry> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
