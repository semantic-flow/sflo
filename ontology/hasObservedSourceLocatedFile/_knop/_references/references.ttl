@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasObservedSourceLocatedFile> sflo:hasReferenceLink <ontology/hasObservedSourceLocatedFile/_knop/_references#reference001> .

<ontology/hasObservedSourceLocatedFile/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/hasObservedSourceLocatedFile> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
