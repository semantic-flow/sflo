@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasPayloadArtifact/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasPayloadArtifact" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasPayloadArtifact/_knop/_inventory/inventory.ttl> .
