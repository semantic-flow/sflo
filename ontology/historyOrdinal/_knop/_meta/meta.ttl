@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/historyOrdinal/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/historyOrdinal" ;
  sflo:hasWorkingKnopInventoryFile <ontology/historyOrdinal/_knop/_inventory/inventory.ttl> .
