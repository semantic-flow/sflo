@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasMeshInventory/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasMeshInventory" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasMeshInventory/_knop/_inventory/inventory.ttl> .
