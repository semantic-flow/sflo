@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/preferredPayloadFileSlug> sflo:hasReferenceLink <ontology/preferredPayloadFileSlug/_knop/_references#reference001> .

<ontology/preferredPayloadFileSlug/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/preferredPayloadFileSlug> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
