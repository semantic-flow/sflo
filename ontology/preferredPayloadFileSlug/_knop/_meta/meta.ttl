@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/preferredPayloadFileSlug/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/preferredPayloadFileSlug" ;
  sflo:hasWorkingKnopInventoryFile <ontology/preferredPayloadFileSlug/_knop/_inventory/inventory.ttl> .
