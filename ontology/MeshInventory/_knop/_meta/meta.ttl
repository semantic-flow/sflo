@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/MeshInventory/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/MeshInventory" ;
  sflo:hasWorkingKnopInventoryFile <ontology/MeshInventory/_knop/_inventory/inventory.ttl> .
