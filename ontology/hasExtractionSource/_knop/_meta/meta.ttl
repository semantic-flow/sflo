@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasExtractionSource/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasExtractionSource" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasExtractionSource/_knop/_inventory/inventory.ttl> .
