@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/workingLocalRelativePath/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/workingLocalRelativePath" ;
  sflo:hasWorkingKnopInventoryFile <ontology/workingLocalRelativePath/_knop/_inventory/inventory.ttl> .
