@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/targetAccessUrl/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/targetAccessUrl" ;
  sflo:hasWorkingKnopInventoryFile <ontology/targetAccessUrl/_knop/_inventory/inventory.ttl> .
