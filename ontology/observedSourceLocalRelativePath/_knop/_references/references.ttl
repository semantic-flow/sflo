@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/observedSourceLocalRelativePath> sflo:hasReferenceLink <ontology/observedSourceLocalRelativePath/_knop/_references#reference001> .

<ontology/observedSourceLocalRelativePath/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/observedSourceLocalRelativePath> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
