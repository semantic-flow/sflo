@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/sourceRepositoryUrl/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/sourceRepositoryUrl" ;
  sflo:hasWorkingKnopInventoryFile <ontology/sourceRepositoryUrl/_knop/_inventory/inventory.ttl> .
