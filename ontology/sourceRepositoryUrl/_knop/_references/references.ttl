@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/sourceRepositoryUrl> sflo:hasReferenceLink <ontology/sourceRepositoryUrl/_knop/_references#reference001> .

<ontology/sourceRepositoryUrl/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/sourceRepositoryUrl> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
