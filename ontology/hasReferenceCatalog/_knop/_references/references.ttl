@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasReferenceCatalog> sflo:hasReferenceLink <ontology/hasReferenceCatalog/_knop/_references#reference001> .

<ontology/hasReferenceCatalog/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/hasReferenceCatalog> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
