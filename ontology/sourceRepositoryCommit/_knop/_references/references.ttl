@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/sourceRepositoryCommit> sflo:hasReferenceLink <ontology/sourceRepositoryCommit/_knop/_references#reference001> .

<ontology/sourceRepositoryCommit/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/sourceRepositoryCommit> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
