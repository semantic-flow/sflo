@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/sourceRepositoryRef/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/sourceRepositoryRef" ;
  sflo:hasWorkingKnopInventoryFile <ontology/sourceRepositoryRef/_knop/_inventory/inventory.ttl> .
