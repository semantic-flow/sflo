@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/referenceTargetState/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/referenceTargetState" ;
  sflo:hasWorkingKnopInventoryFile <ontology/referenceTargetState/_knop/_inventory/inventory.ttl> .
