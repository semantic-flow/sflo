@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/nextHistoryOrdinal> sflo:hasReferenceLink <ontology/nextHistoryOrdinal/_knop/_references#reference001> .

<ontology/nextHistoryOrdinal/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/nextHistoryOrdinal> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
