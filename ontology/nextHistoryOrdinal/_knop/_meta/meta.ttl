@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/nextHistoryOrdinal/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/nextHistoryOrdinal" ;
  sflo:hasWorkingKnopInventoryFile <ontology/nextHistoryOrdinal/_knop/_inventory/inventory.ttl> .
