@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/KnopInventory/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/KnopInventory" ;
  sflo:hasWorkingKnopInventoryFile <ontology/KnopInventory/_knop/_inventory/inventory.ttl> .
