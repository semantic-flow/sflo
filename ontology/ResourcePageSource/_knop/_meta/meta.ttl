@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/ResourcePageSource/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/ResourcePageSource" ;
  sflo:hasWorkingKnopInventoryFile <ontology/ResourcePageSource/_knop/_inventory/inventory.ttl> .
