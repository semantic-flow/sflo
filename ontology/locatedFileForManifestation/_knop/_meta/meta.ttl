@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/locatedFileForManifestation/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/locatedFileForManifestation" ;
  sflo:hasWorkingKnopInventoryFile <ontology/locatedFileForManifestation/_knop/_inventory/inventory.ttl> .
