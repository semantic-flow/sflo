@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/workingAccessUrl/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/workingAccessUrl" ;
  sflo:hasWorkingKnopInventoryFile <ontology/workingAccessUrl/_knop/_inventory/inventory.ttl> .
