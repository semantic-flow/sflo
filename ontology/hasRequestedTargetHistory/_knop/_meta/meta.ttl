@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasRequestedTargetHistory/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasRequestedTargetHistory" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasRequestedTargetHistory/_knop/_inventory/inventory.ttl> .
