@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasRequestedTargetHistory> sflo:hasReferenceLink <ontology/hasRequestedTargetHistory/_knop/_references#reference001> .

<ontology/hasRequestedTargetHistory/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/hasRequestedTargetHistory> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
