@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasTargetRepositorySource/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasTargetRepositorySource" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasTargetRepositorySource/_knop/_inventory/inventory.ttl> .
