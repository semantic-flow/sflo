@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasTargetRepositorySource> sflo:hasReferenceLink <ontology/hasTargetRepositorySource/_knop/_references#reference001> .

<ontology/hasTargetRepositorySource/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/hasTargetRepositorySource> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
