@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/referenceLinkFor/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/referenceLinkFor" ;
  sflo:hasWorkingKnopInventoryFile <ontology/referenceLinkFor/_knop/_inventory/inventory.ttl> .
