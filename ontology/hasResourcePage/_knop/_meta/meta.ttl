@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasResourcePage/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasResourcePage" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasResourcePage/_knop/_inventory/inventory.ttl> .
