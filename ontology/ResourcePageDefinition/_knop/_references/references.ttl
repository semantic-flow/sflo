@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/ResourcePageDefinition> sflo:hasReferenceLink <ontology/ResourcePageDefinition/_knop/_references#reference001> .

<ontology/ResourcePageDefinition/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/ResourcePageDefinition> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
