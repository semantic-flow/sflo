@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/ResourcePageDefinition/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/ResourcePageDefinition" ;
  sflo:hasWorkingKnopInventoryFile <ontology/ResourcePageDefinition/_knop/_inventory/inventory.ttl> .
