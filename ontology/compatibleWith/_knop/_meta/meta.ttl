@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/compatibleWith/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/compatibleWith" ;
  sflo:hasWorkingKnopInventoryFile <ontology/compatibleWith/_knop/_inventory/inventory.ttl> .
