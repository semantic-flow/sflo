@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasTargetLocatedFile/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasTargetLocatedFile" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasTargetLocatedFile/_knop/_inventory/inventory.ttl> .
