@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/ArtifactResolutionMode> sflo:hasReferenceLink <ontology/ArtifactResolutionMode/_knop/_references#reference001> .

<ontology/ArtifactResolutionMode/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/ArtifactResolutionMode> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
