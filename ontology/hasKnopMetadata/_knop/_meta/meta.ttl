@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasKnopMetadata/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasKnopMetadata" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasKnopMetadata/_knop/_inventory/inventory.ttl> .
