@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasArtifactResolutionMode> sflo:hasReferenceLink <ontology/hasArtifactResolutionMode/_knop/_references#reference001> .

<ontology/hasArtifactResolutionMode/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/hasArtifactResolutionMode> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
