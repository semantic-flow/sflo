@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasTargetDistribution/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasTargetDistribution" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasTargetDistribution/_knop/_inventory/inventory.ttl> .
