<ontology/shacl/ArtifactHistoryShape/_knop/_sources> a sflo:KnopSourceRegistry, sflo:DigitalArtifact, sflo:RdfDocument ;
  sflo:hasWorkingLocatedFile <ontology/shacl/ArtifactHistoryShape/_knop/_sources/sources.ttl> ;
  sflo:hasSourceBinding <ontology/shacl/ArtifactHistoryShape/_knop/_sources#extraction-source> .

