@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/shacl/PreferredPayloadFileSlugShape/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/shacl/PreferredPayloadFileSlugShape" ;
  sflo:hasWorkingKnopInventoryFile <ontology/shacl/PreferredPayloadFileSlugShape/_knop/_inventory/inventory.ttl> .
