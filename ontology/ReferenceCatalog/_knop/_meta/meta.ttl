@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/ReferenceCatalog/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/ReferenceCatalog" ;
  sflo:hasWorkingKnopInventoryFile <ontology/ReferenceCatalog/_knop/_inventory/inventory.ttl> .
