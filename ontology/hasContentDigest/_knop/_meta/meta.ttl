@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasContentDigest/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasContentDigest" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasContentDigest/_knop/_inventory/inventory.ttl> .
