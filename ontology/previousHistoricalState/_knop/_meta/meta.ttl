@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/previousHistoricalState/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/previousHistoricalState" ;
  sflo:hasWorkingKnopInventoryFile <ontology/previousHistoricalState/_knop/_inventory/inventory.ttl> .
