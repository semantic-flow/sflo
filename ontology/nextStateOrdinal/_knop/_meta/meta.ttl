@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/nextStateOrdinal/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/nextStateOrdinal" ;
  sflo:hasWorkingKnopInventoryFile <ontology/nextStateOrdinal/_knop/_inventory/inventory.ttl> .
