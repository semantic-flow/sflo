@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasMeshMetadata> sflo:hasReferenceLink <ontology/hasMeshMetadata/_knop/_references#reference001> .

<ontology/hasMeshMetadata/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/hasMeshMetadata> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
