@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/currentArtifactHistory/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/currentArtifactHistory" ;
  sflo:hasWorkingKnopInventoryFile <ontology/currentArtifactHistory/_knop/_inventory/inventory.ttl> .
