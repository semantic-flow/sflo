@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/currentArtifactHistory> sflo:hasReferenceLink <ontology/currentArtifactHistory/_knop/_references#reference001> .

<ontology/currentArtifactHistory/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/currentArtifactHistory> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
