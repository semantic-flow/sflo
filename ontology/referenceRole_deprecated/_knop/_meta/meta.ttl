@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/referenceRole_deprecated/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/referenceRole_deprecated" ;
  sflo:hasWorkingKnopInventoryFile <ontology/referenceRole_deprecated/_knop/_inventory/inventory.ttl> .
