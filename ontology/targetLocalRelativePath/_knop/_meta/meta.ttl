@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/targetLocalRelativePath/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/targetLocalRelativePath" ;
  sflo:hasWorkingKnopInventoryFile <ontology/targetLocalRelativePath/_knop/_inventory/inventory.ttl> .
