@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/targetLocalRelativePath> sflo:hasReferenceLink <ontology/targetLocalRelativePath/_knop/_references#reference001> .

<ontology/targetLocalRelativePath/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/targetLocalRelativePath> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
