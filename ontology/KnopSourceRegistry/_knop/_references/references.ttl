@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/KnopSourceRegistry> sflo:hasReferenceLink <ontology/KnopSourceRegistry/_knop/_references#reference001> .

<ontology/KnopSourceRegistry/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/KnopSourceRegistry> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
