@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/KnopSourceRegistry/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/KnopSourceRegistry" ;
  sflo:hasWorkingKnopInventoryFile <ontology/KnopSourceRegistry/_knop/_inventory/inventory.ttl> .
