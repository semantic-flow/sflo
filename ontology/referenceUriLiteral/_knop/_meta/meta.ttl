@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/referenceUriLiteral/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/referenceUriLiteral" ;
  sflo:hasWorkingKnopInventoryFile <ontology/referenceUriLiteral/_knop/_inventory/inventory.ttl> .
