@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/DigitalArtifactFacet> sflo:hasReferenceLink <ontology/DigitalArtifactFacet/_knop/_references#reference001> .

<ontology/DigitalArtifactFacet/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/DigitalArtifactFacet> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
