@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/latestHistoricalState/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/latestHistoricalState" ;
  sflo:hasWorkingKnopInventoryFile <ontology/latestHistoricalState/_knop/_inventory/inventory.ttl> .
