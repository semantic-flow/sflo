@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasPageRegion> sflo:hasReferenceLink <ontology/hasPageRegion/_knop/_references#reference001> .

<ontology/hasPageRegion/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/hasPageRegion> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
