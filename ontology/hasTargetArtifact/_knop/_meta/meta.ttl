@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasTargetArtifact/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasTargetArtifact" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasTargetArtifact/_knop/_inventory/inventory.ttl> .
