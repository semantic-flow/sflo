@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/KnopAssetBundle/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/KnopAssetBundle" ;
  sflo:hasWorkingKnopInventoryFile <ontology/KnopAssetBundle/_knop/_inventory/inventory.ttl> .
