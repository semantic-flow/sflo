@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/ExtractionSource/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/ExtractionSource" ;
  sflo:hasWorkingKnopInventoryFile <ontology/ExtractionSource/_knop/_inventory/inventory.ttl> .
