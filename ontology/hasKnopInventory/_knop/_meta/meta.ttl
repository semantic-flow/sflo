@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasKnopInventory/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/hasKnopInventory" ;
  sflo:hasWorkingKnopInventoryFile <ontology/hasKnopInventory/_knop/_inventory/inventory.ttl> .
