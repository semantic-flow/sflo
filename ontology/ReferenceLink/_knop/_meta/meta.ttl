@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/ReferenceLink/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/ReferenceLink" ;
  sflo:hasWorkingKnopInventoryFile <ontology/ReferenceLink/_knop/_inventory/inventory.ttl> .
