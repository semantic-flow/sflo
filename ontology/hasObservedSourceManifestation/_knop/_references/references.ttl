@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/hasObservedSourceManifestation> sflo:hasReferenceLink <ontology/hasObservedSourceManifestation/_knop/_references#reference001> .

<ontology/hasObservedSourceManifestation/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <ontology/hasObservedSourceManifestation> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <ontology> .
