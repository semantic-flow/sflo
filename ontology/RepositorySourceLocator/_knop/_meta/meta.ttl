@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<ontology/RepositorySourceLocator/_knop> a sflo:Knop ;
  sflo:designatorPath "ontology/RepositorySourceLocator" ;
  sflo:hasWorkingKnopInventoryFile <ontology/RepositorySourceLocator/_knop/_inventory/inventory.ttl> .
