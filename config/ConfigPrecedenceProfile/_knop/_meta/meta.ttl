@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ConfigPrecedenceProfile/_knop> a sflo:Knop ;
  sflo:designatorPath "config/ConfigPrecedenceProfile" ;
  sflo:hasWorkingKnopInventoryFile <config/ConfigPrecedenceProfile/_knop/_inventory/inventory.ttl> .
