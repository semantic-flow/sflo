@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ConfigPrecedenceProfile> sflo:hasReferenceLink <config/ConfigPrecedenceProfile/_knop/_references#reference001> .

<config/ConfigPrecedenceProfile/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/ConfigPrecedenceProfile> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
