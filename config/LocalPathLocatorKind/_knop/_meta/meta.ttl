@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/LocalPathLocatorKind/_knop> a sflo:Knop ;
  sflo:designatorPath "config/LocalPathLocatorKind" ;
  sflo:hasWorkingKnopInventoryFile <config/LocalPathLocatorKind/_knop/_inventory/inventory.ttl> .
