@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasConfigResolutionStatus> sflo:hasReferenceLink <config/hasConfigResolutionStatus/_knop/_references#reference001> .

<config/hasConfigResolutionStatus/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasConfigResolutionStatus> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
