@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasConfigResolutionStatus/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasConfigResolutionStatus" ;
  sflo:hasWorkingKnopInventoryFile <config/hasConfigResolutionStatus/_knop/_inventory/inventory.ttl> .
