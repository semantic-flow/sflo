@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ManifestationNamingPolicy> sflo:hasReferenceLink <config/ManifestationNamingPolicy/_knop/_references#reference001> .

<config/ManifestationNamingPolicy/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/ManifestationNamingPolicy> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
