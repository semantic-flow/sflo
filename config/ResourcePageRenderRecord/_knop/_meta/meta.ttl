@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ResourcePageRenderRecord/_knop> a sflo:Knop ;
  sflo:designatorPath "config/ResourcePageRenderRecord" ;
  sflo:hasWorkingKnopInventoryFile <config/ResourcePageRenderRecord/_knop/_inventory/inventory.ttl> .
