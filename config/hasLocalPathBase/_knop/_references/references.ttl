@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasLocalPathBase> sflo:hasReferenceLink <config/hasLocalPathBase/_knop/_references#reference001> .

<config/hasLocalPathBase/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasLocalPathBase> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
