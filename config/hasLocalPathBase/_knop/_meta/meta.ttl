@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasLocalPathBase/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasLocalPathBase" ;
  sflo:hasWorkingKnopInventoryFile <config/hasLocalPathBase/_knop/_inventory/inventory.ttl> .
