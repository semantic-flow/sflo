@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/HostLocalOperationalConfig/_knop> a sflo:Knop ;
  sflo:designatorPath "config/HostLocalOperationalConfig" ;
  sflo:hasWorkingKnopInventoryFile <config/HostLocalOperationalConfig/_knop/_inventory/inventory.ttl> .
