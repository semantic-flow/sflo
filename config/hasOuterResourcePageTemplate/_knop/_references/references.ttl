@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasOuterResourcePageTemplate> sflo:hasReferenceLink <config/hasOuterResourcePageTemplate/_knop/_references#reference001> .

<config/hasOuterResourcePageTemplate/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasOuterResourcePageTemplate> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
