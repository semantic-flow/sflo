@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasConfigScope> sflo:hasReferenceLink <config/hasConfigScope/_knop/_references#reference001> .

<config/hasConfigScope/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasConfigScope> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
