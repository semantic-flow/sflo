@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasDefaultHistorySegmentHint> sflo:hasReferenceLink <config/hasDefaultHistorySegmentHint/_knop/_references#reference001> .

<config/hasDefaultHistorySegmentHint/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasDefaultHistorySegmentHint> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
