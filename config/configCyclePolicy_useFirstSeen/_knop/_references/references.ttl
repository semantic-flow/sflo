@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/configCyclePolicy_useFirstSeen> sflo:hasReferenceLink <config/configCyclePolicy_useFirstSeen/_knop/_references#reference001> .

<config/configCyclePolicy_useFirstSeen/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/configCyclePolicy_useFirstSeen> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
