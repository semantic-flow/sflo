@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/configCyclePolicy_useFirstSeen/_knop> a sflo:Knop ;
  sflo:designatorPath "config/configCyclePolicy_useFirstSeen" ;
  sflo:hasWorkingKnopInventoryFile <config/configCyclePolicy_useFirstSeen/_knop/_inventory/inventory.ttl> .
