@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResolvedConfig/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasResolvedConfig" ;
  sflo:hasWorkingKnopInventoryFile <config/hasResolvedConfig/_knop/_inventory/inventory.ttl> .
