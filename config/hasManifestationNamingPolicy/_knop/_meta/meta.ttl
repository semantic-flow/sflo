@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasManifestationNamingPolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasManifestationNamingPolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/hasManifestationNamingPolicy/_knop/_inventory/inventory.ttl> .
