@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasKnopInheritableConfigSource> sflo:hasReferenceLink <config/hasKnopInheritableConfigSource/_knop/_references#reference001> .

<config/hasKnopInheritableConfigSource/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasKnopInheritableConfigSource> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
