@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResourcePagePresentationConfig/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasResourcePagePresentationConfig" ;
  sflo:hasWorkingKnopInventoryFile <config/hasResourcePagePresentationConfig/_knop/_inventory/inventory.ttl> .
