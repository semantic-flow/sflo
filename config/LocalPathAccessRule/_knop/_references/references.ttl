@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/LocalPathAccessRule> sflo:hasReferenceLink <config/LocalPathAccessRule/_knop/_references#reference001> .

<config/LocalPathAccessRule/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/LocalPathAccessRule> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
