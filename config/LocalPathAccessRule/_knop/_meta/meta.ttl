@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/LocalPathAccessRule/_knop> a sflo:Knop ;
  sflo:designatorPath "config/LocalPathAccessRule" ;
  sflo:hasWorkingKnopInventoryFile <config/LocalPathAccessRule/_knop/_inventory/inventory.ttl> .
