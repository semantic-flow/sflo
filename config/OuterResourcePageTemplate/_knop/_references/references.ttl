@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/OuterResourcePageTemplate> sflo:hasReferenceLink <config/OuterResourcePageTemplate/_knop/_references#reference001> .

<config/OuterResourcePageTemplate/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/OuterResourcePageTemplate> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
