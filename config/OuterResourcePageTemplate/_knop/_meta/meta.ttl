@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/OuterResourcePageTemplate/_knop> a sflo:Knop ;
  sflo:designatorPath "config/OuterResourcePageTemplate" ;
  sflo:hasWorkingKnopInventoryFile <config/OuterResourcePageTemplate/_knop/_inventory/inventory.ttl> .
