@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasConfigMergeProfile/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasConfigMergeProfile" ;
  sflo:hasWorkingKnopInventoryFile <config/hasConfigMergeProfile/_knop/_inventory/inventory.ttl> .
