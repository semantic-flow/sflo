@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasConfigPrecedenceProfile> sflo:hasReferenceLink <config/hasConfigPrecedenceProfile/_knop/_references#reference001> .

<config/hasConfigPrecedenceProfile/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasConfigPrecedenceProfile> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
