@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasConfigPrecedenceProfile/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasConfigPrecedenceProfile" ;
  sflo:hasWorkingKnopInventoryFile <config/hasConfigPrecedenceProfile/_knop/_inventory/inventory.ttl> .
