@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/configLayerRole_commandOverride> sflo:hasReferenceLink <config/configLayerRole_commandOverride/_knop/_references#reference001> .

<config/configLayerRole_commandOverride/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/configLayerRole_commandOverride> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
