@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/StateNamingPolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/StateNamingPolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/StateNamingPolicy/_knop/_inventory/inventory.ttl> .
