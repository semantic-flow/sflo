@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/remoteLocatorKind_targetAccessUrl/_knop> a sflo:Knop ;
  sflo:designatorPath "config/remoteLocatorKind_targetAccessUrl" ;
  sflo:hasWorkingKnopInventoryFile <config/remoteLocatorKind_targetAccessUrl/_knop/_inventory/inventory.ttl> .
