@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasConfigCyclePolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasConfigCyclePolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/hasConfigCyclePolicy/_knop/_inventory/inventory.ttl> .
