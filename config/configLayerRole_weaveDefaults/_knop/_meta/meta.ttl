@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/configLayerRole_weaveDefaults/_knop> a sflo:Knop ;
  sflo:designatorPath "config/configLayerRole_weaveDefaults" ;
  sflo:hasWorkingKnopInventoryFile <config/configLayerRole_weaveDefaults/_knop/_inventory/inventory.ttl> .
