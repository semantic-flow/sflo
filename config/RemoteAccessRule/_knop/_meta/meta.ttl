@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/RemoteAccessRule/_knop> a sflo:Knop ;
  sflo:designatorPath "config/RemoteAccessRule" ;
  sflo:hasWorkingKnopInventoryFile <config/RemoteAccessRule/_knop/_inventory/inventory.ttl> .
