@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/WorkspaceOperationalConfig> sflo:hasReferenceLink <config/WorkspaceOperationalConfig/_knop/_references#reference001> .

<config/WorkspaceOperationalConfig/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/WorkspaceOperationalConfig> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
