@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/WorkspaceOperationalConfig/_knop> a sflo:Knop ;
  sflo:designatorPath "config/WorkspaceOperationalConfig" ;
  sflo:hasWorkingKnopInventoryFile <config/WorkspaceOperationalConfig/_knop/_inventory/inventory.ttl> .
