@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ResolvedConfigCachePolicy> sflo:hasReferenceLink <config/ResolvedConfigCachePolicy/_knop/_references#reference001> .

<config/ResolvedConfigCachePolicy/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/ResolvedConfigCachePolicy> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
