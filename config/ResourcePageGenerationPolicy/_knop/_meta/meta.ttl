@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ResourcePageGenerationPolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/ResourcePageGenerationPolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/ResourcePageGenerationPolicy/_knop/_inventory/inventory.ttl> .
