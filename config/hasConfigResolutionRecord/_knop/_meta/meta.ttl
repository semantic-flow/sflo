@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasConfigResolutionRecord/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasConfigResolutionRecord" ;
  sflo:hasWorkingKnopInventoryFile <config/hasConfigResolutionRecord/_knop/_inventory/inventory.ttl> .
