@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/renderedFromSourceState/_knop> a sflo:Knop ;
  sflo:designatorPath "config/renderedFromSourceState" ;
  sflo:hasWorkingKnopInventoryFile <config/renderedFromSourceState/_knop/_inventory/inventory.ttl> .
