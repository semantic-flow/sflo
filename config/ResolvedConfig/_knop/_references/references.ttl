@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ResolvedConfig> sflo:hasReferenceLink <config/ResolvedConfig/_knop/_references#reference001> .

<config/ResolvedConfig/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/ResolvedConfig> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
