@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasMeshInheritableConfig/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasMeshInheritableConfig" ;
  sflo:hasWorkingKnopInventoryFile <config/hasMeshInheritableConfig/_knop/_inventory/inventory.ttl> .
