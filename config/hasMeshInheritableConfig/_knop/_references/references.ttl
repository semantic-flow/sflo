@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasMeshInheritableConfig> sflo:hasReferenceLink <config/hasMeshInheritableConfig/_knop/_references#reference001> .

<config/hasMeshInheritableConfig/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasMeshInheritableConfig> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
