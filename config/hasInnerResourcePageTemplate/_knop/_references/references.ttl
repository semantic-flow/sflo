@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasInnerResourcePageTemplate> sflo:hasReferenceLink <config/hasInnerResourcePageTemplate/_knop/_references#reference001> .

<config/hasInnerResourcePageTemplate/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasInnerResourcePageTemplate> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
