@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/localPathBase_absolutePath> sflo:hasReferenceLink <config/localPathBase_absolutePath/_knop/_references#reference001> .

<config/localPathBase_absolutePath/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/localPathBase_absolutePath> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
