@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/localPathLocatorKind_workingLocalRelativePath> sflo:hasReferenceLink <config/localPathLocatorKind_workingLocalRelativePath/_knop/_references#reference001> .

<config/localPathLocatorKind_workingLocalRelativePath/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/localPathLocatorKind_workingLocalRelativePath> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
