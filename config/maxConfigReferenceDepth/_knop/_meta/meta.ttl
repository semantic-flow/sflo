@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/maxConfigReferenceDepth/_knop> a sflo:Knop ;
  sflo:designatorPath "config/maxConfigReferenceDepth" ;
  sflo:hasWorkingKnopInventoryFile <config/maxConfigReferenceDepth/_knop/_inventory/inventory.ttl> .
