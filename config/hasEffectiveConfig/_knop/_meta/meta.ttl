@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasEffectiveConfig/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasEffectiveConfig" ;
  sflo:hasWorkingKnopInventoryFile <config/hasEffectiveConfig/_knop/_inventory/inventory.ttl> .
