@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasLocalPathAccessRule/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasLocalPathAccessRule" ;
  sflo:hasWorkingKnopInventoryFile <config/hasLocalPathAccessRule/_knop/_inventory/inventory.ttl> .
