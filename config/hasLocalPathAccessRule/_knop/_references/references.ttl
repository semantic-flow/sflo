@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasLocalPathAccessRule> sflo:hasReferenceLink <config/hasLocalPathAccessRule/_knop/_references#reference001> .

<config/hasLocalPathAccessRule/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasLocalPathAccessRule> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
