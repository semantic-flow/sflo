@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResourcePageRegenerationConfigPolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasResourcePageRegenerationConfigPolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/hasResourcePageRegenerationConfigPolicy/_knop/_inventory/inventory.ttl> .
