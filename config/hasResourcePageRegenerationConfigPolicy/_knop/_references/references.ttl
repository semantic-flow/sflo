@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResourcePageRegenerationConfigPolicy> sflo:hasReferenceLink <config/hasResourcePageRegenerationConfigPolicy/_knop/_references#reference001> .

<config/hasResourcePageRegenerationConfigPolicy/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasResourcePageRegenerationConfigPolicy> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
