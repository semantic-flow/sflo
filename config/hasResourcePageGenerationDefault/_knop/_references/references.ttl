@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResourcePageGenerationDefault> sflo:hasReferenceLink <config/hasResourcePageGenerationDefault/_knop/_references#reference001> .

<config/hasResourcePageGenerationDefault/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasResourcePageGenerationDefault> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
