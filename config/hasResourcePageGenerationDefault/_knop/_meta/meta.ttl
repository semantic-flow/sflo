@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResourcePageGenerationDefault/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasResourcePageGenerationDefault" ;
  sflo:hasWorkingKnopInventoryFile <config/hasResourcePageGenerationDefault/_knop/_inventory/inventory.ttl> .
