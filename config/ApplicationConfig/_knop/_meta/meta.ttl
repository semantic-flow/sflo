@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ApplicationConfig/_knop> a sflo:Knop ;
  sflo:designatorPath "config/ApplicationConfig" ;
  sflo:hasWorkingKnopInventoryFile <config/ApplicationConfig/_knop/_inventory/inventory.ttl> .
