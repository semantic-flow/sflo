@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResolvedConfigDigest/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasResolvedConfigDigest" ;
  sflo:hasWorkingKnopInventoryFile <config/hasResolvedConfigDigest/_knop/_inventory/inventory.ttl> .
