@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResolvedConfigDigest> sflo:hasReferenceLink <config/hasResolvedConfigDigest/_knop/_references#reference001> .

<config/hasResolvedConfigDigest/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasResolvedConfigDigest> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
