@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasDefaultResourcePageGenerationPolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasDefaultResourcePageGenerationPolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/hasDefaultResourcePageGenerationPolicy/_knop/_inventory/inventory.ttl> .
