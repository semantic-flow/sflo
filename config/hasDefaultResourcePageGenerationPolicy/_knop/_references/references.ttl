@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasDefaultResourcePageGenerationPolicy> sflo:hasReferenceLink <config/hasDefaultResourcePageGenerationPolicy/_knop/_references#reference001> .

<config/hasDefaultResourcePageGenerationPolicy/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasDefaultResourcePageGenerationPolicy> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
