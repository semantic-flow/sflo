@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasPortableResolverHintPolicy> sflo:hasReferenceLink <config/hasPortableResolverHintPolicy/_knop/_references#reference001> .

<config/hasPortableResolverHintPolicy/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasPortableResolverHintPolicy> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
