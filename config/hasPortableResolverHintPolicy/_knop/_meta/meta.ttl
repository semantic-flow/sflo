@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasPortableResolverHintPolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasPortableResolverHintPolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/hasPortableResolverHintPolicy/_knop/_inventory/inventory.ttl> .
