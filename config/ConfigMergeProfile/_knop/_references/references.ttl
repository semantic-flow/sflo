@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ConfigMergeProfile> sflo:hasReferenceLink <config/ConfigMergeProfile/_knop/_references#reference001> .

<config/ConfigMergeProfile/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/ConfigMergeProfile> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
