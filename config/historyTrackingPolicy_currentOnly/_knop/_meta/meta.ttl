@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/historyTrackingPolicy_currentOnly/_knop> a sflo:Knop ;
  sflo:designatorPath "config/historyTrackingPolicy_currentOnly" ;
  sflo:hasWorkingKnopInventoryFile <config/historyTrackingPolicy_currentOnly/_knop/_inventory/inventory.ttl> .
