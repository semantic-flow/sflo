@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasHistoryTrackingDefault> sflo:hasReferenceLink <config/hasHistoryTrackingDefault/_knop/_references#reference001> .

<config/hasHistoryTrackingDefault/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasHistoryTrackingDefault> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
