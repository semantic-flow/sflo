@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/portableResolverHintPolicy_ignore/_knop> a sflo:Knop ;
  sflo:designatorPath "config/portableResolverHintPolicy_ignore" ;
  sflo:hasWorkingKnopInventoryFile <config/portableResolverHintPolicy_ignore/_knop/_inventory/inventory.ttl> .
