@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/portableResolverHintPolicy_ignore> sflo:hasReferenceLink <config/portableResolverHintPolicy_ignore/_knop/_references#reference001> .

<config/portableResolverHintPolicy_ignore/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/portableResolverHintPolicy_ignore> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
