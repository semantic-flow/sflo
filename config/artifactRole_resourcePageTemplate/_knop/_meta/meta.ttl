@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/artifactRole_resourcePageTemplate/_knop> a sflo:Knop ;
  sflo:designatorPath "config/artifactRole_resourcePageTemplate" ;
  sflo:hasWorkingKnopInventoryFile <config/artifactRole_resourcePageTemplate/_knop/_inventory/inventory.ttl> .
