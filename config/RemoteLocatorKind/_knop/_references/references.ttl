@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/RemoteLocatorKind> sflo:hasReferenceLink <config/RemoteLocatorKind/_knop/_references#reference001> .

<config/RemoteLocatorKind/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/RemoteLocatorKind> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
