@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/RemoteLocatorKind/_knop> a sflo:Knop ;
  sflo:designatorPath "config/RemoteLocatorKind" ;
  sflo:hasWorkingKnopInventoryFile <config/RemoteLocatorKind/_knop/_inventory/inventory.ttl> .
