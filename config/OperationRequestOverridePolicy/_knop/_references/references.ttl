@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/OperationRequestOverridePolicy> sflo:hasReferenceLink <config/OperationRequestOverridePolicy/_knop/_references#reference001> .

<config/OperationRequestOverridePolicy/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/OperationRequestOverridePolicy> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
