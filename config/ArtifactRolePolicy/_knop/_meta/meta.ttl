@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ArtifactRolePolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/ArtifactRolePolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/ArtifactRolePolicy/_knop/_inventory/inventory.ttl> .
