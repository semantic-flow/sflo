@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasConfigReferencePolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasConfigReferencePolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/hasConfigReferencePolicy/_knop/_inventory/inventory.ttl> .
