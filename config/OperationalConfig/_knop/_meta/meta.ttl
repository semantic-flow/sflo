@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/OperationalConfig/_knop> a sflo:Knop ;
  sflo:designatorPath "config/OperationalConfig" ;
  sflo:hasWorkingKnopInventoryFile <config/OperationalConfig/_knop/_inventory/inventory.ttl> .
