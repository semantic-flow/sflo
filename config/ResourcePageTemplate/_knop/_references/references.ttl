@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ResourcePageTemplate> sflo:hasReferenceLink <config/ResourcePageTemplate/_knop/_references#reference001> .

<config/ResourcePageTemplate/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/ResourcePageTemplate> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
