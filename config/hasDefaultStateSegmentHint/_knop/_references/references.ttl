@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasDefaultStateSegmentHint> sflo:hasReferenceLink <config/hasDefaultStateSegmentHint/_knop/_references#reference001> .

<config/hasDefaultStateSegmentHint/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasDefaultStateSegmentHint> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
