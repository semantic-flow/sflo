@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasHistoryTrackingPolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasHistoryTrackingPolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/hasHistoryTrackingPolicy/_knop/_inventory/inventory.ttl> .
