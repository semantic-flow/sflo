@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasKnopLocalConfigSource/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasKnopLocalConfigSource" ;
  sflo:hasWorkingKnopInventoryFile <config/hasKnopLocalConfigSource/_knop/_inventory/inventory.ttl> .
