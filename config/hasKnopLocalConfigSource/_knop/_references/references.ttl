@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasKnopLocalConfigSource> sflo:hasReferenceLink <config/hasKnopLocalConfigSource/_knop/_references#reference001> .

<config/hasKnopLocalConfigSource/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasKnopLocalConfigSource> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
