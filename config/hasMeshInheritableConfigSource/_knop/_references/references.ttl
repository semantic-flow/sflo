@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasMeshInheritableConfigSource> sflo:hasReferenceLink <config/hasMeshInheritableConfigSource/_knop/_references#reference001> .

<config/hasMeshInheritableConfigSource/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasMeshInheritableConfigSource> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
