@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasRemoteLocatorKind/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasRemoteLocatorKind" ;
  sflo:hasWorkingKnopInventoryFile <config/hasRemoteLocatorKind/_knop/_inventory/inventory.ttl> .
