@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasRemoteLocatorKind> sflo:hasReferenceLink <config/hasRemoteLocatorKind/_knop/_references#reference001> .

<config/hasRemoteLocatorKind/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasRemoteLocatorKind> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
