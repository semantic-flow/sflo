@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ResourcePageRegenerationConfigPolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/ResourcePageRegenerationConfigPolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/ResourcePageRegenerationConfigPolicy/_knop/_inventory/inventory.ttl> .
