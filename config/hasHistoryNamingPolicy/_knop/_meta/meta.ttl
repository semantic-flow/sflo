@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasHistoryNamingPolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasHistoryNamingPolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/hasHistoryNamingPolicy/_knop/_inventory/inventory.ttl> .
