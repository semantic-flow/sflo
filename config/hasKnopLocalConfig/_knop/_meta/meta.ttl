@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasKnopLocalConfig/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasKnopLocalConfig" ;
  sflo:hasWorkingKnopInventoryFile <config/hasKnopLocalConfig/_knop/_inventory/inventory.ttl> .
