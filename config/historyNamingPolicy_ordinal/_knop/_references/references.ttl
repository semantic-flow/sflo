@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/historyNamingPolicy_ordinal> sflo:hasReferenceLink <config/historyNamingPolicy_ordinal/_knop/_references#reference001> .

<config/historyNamingPolicy_ordinal/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/historyNamingPolicy_ordinal> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
