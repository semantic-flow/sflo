@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/resolvedFromConfig> sflo:hasReferenceLink <config/resolvedFromConfig/_knop/_references#reference001> .

<config/resolvedFromConfig/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/resolvedFromConfig> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
