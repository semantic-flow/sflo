@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasLocalPathLocatorKind> sflo:hasReferenceLink <config/hasLocalPathLocatorKind/_knop/_references#reference001> .

<config/hasLocalPathLocatorKind/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasLocalPathLocatorKind> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
