@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasLocalPathLocatorKind/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasLocalPathLocatorKind" ;
  sflo:hasWorkingKnopInventoryFile <config/hasLocalPathLocatorKind/_knop/_inventory/inventory.ttl> .
