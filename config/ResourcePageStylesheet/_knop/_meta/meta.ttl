@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ResourcePageStylesheet/_knop> a sflo:Knop ;
  sflo:designatorPath "config/ResourcePageStylesheet" ;
  sflo:hasWorkingKnopInventoryFile <config/ResourcePageStylesheet/_knop/_inventory/inventory.ttl> .
