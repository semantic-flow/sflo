@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/localPathBase_meshRoot/_knop> a sflo:Knop ;
  sflo:designatorPath "config/localPathBase_meshRoot" ;
  sflo:hasWorkingKnopInventoryFile <config/localPathBase_meshRoot/_knop/_inventory/inventory.ttl> .
