@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasConfigSource/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasConfigSource" ;
  sflo:hasWorkingKnopInventoryFile <config/hasConfigSource/_knop/_inventory/inventory.ttl> .
