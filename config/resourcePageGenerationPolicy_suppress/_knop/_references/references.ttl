@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/resourcePageGenerationPolicy_suppress> sflo:hasReferenceLink <config/resourcePageGenerationPolicy_suppress/_knop/_references#reference001> .

<config/resourcePageGenerationPolicy_suppress/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/resourcePageGenerationPolicy_suppress> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
