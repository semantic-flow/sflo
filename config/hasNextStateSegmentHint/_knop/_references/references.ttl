@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasNextStateSegmentHint> sflo:hasReferenceLink <config/hasNextStateSegmentHint/_knop/_references#reference001> .

<config/hasNextStateSegmentHint/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasNextStateSegmentHint> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
