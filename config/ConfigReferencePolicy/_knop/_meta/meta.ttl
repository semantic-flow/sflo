@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ConfigReferencePolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/ConfigReferencePolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/ConfigReferencePolicy/_knop/_inventory/inventory.ttl> .
