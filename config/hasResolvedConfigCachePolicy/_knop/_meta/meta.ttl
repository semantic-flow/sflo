@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResolvedConfigCachePolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasResolvedConfigCachePolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/hasResolvedConfigCachePolicy/_knop/_inventory/inventory.ttl> .
