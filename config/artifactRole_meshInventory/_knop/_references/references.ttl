@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/artifactRole_meshInventory> sflo:hasReferenceLink <config/artifactRole_meshInventory/_knop/_references#reference001> .

<config/artifactRole_meshInventory/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/artifactRole_meshInventory> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
