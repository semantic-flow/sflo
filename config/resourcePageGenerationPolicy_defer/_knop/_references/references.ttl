@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/resourcePageGenerationPolicy_defer> sflo:hasReferenceLink <config/resourcePageGenerationPolicy_defer/_knop/_references#reference001> .

<config/resourcePageGenerationPolicy_defer/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/resourcePageGenerationPolicy_defer> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
