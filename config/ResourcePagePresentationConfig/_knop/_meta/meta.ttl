@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ResourcePagePresentationConfig/_knop> a sflo:Knop ;
  sflo:designatorPath "config/ResourcePagePresentationConfig" ;
  sflo:hasWorkingKnopInventoryFile <config/ResourcePagePresentationConfig/_knop/_inventory/inventory.ttl> .
