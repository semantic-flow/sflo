@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ResourcePagePresentationConfig> sflo:hasReferenceLink <config/ResourcePagePresentationConfig/_knop/_references#reference001> .

<config/ResourcePagePresentationConfig/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/ResourcePagePresentationConfig> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
