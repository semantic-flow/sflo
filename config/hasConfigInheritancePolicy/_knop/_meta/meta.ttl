@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasConfigInheritancePolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasConfigInheritancePolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/hasConfigInheritancePolicy/_knop/_inventory/inventory.ttl> .
