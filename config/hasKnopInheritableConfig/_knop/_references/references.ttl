@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasKnopInheritableConfig> sflo:hasReferenceLink <config/hasKnopInheritableConfig/_knop/_references#reference001> .

<config/hasKnopInheritableConfig/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasKnopInheritableConfig> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
