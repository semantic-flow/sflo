@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasNextHistorySegmentHint/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasNextHistorySegmentHint" ;
  sflo:hasWorkingKnopInventoryFile <config/hasNextHistorySegmentHint/_knop/_inventory/inventory.ttl> .
