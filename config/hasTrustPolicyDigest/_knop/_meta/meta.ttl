@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasTrustPolicyDigest/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasTrustPolicyDigest" ;
  sflo:hasWorkingKnopInventoryFile <config/hasTrustPolicyDigest/_knop/_inventory/inventory.ttl> .
