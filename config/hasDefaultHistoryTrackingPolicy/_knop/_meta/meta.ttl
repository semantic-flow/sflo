@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasDefaultHistoryTrackingPolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasDefaultHistoryTrackingPolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/hasDefaultHistoryTrackingPolicy/_knop/_inventory/inventory.ttl> .
