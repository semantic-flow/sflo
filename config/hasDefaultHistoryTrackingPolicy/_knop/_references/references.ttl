@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasDefaultHistoryTrackingPolicy> sflo:hasReferenceLink <config/hasDefaultHistoryTrackingPolicy/_knop/_references#reference001> .

<config/hasDefaultHistoryTrackingPolicy/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasDefaultHistoryTrackingPolicy> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
