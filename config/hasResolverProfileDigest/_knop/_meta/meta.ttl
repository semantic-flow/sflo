@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResolverProfileDigest/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasResolverProfileDigest" ;
  sflo:hasWorkingKnopInventoryFile <config/hasResolverProfileDigest/_knop/_inventory/inventory.ttl> .
