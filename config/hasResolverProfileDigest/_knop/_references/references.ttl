@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResolverProfileDigest> sflo:hasReferenceLink <config/hasResolverProfileDigest/_knop/_references#reference001> .

<config/hasResolverProfileDigest/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasResolverProfileDigest> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
