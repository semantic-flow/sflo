@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResolvedConfigFor/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasResolvedConfigFor" ;
  sflo:hasWorkingKnopInventoryFile <config/hasResolvedConfigFor/_knop/_inventory/inventory.ttl> .
