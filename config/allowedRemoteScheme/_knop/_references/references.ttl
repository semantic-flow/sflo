@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/allowedRemoteScheme> sflo:hasReferenceLink <config/allowedRemoteScheme/_knop/_references#reference001> .

<config/allowedRemoteScheme/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/allowedRemoteScheme> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
