@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ConfigResolutionStatus/_knop> a sflo:Knop ;
  sflo:designatorPath "config/ConfigResolutionStatus" ;
  sflo:hasWorkingKnopInventoryFile <config/ConfigResolutionStatus/_knop/_inventory/inventory.ttl> .
