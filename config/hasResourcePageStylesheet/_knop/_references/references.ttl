@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResourcePageStylesheet> sflo:hasReferenceLink <config/hasResourcePageStylesheet/_knop/_references#reference001> .

<config/hasResourcePageStylesheet/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasResourcePageStylesheet> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
