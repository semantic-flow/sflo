@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResourcePageStylesheet/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasResourcePageStylesheet" ;
  sflo:hasWorkingKnopInventoryFile <config/hasResourcePageStylesheet/_knop/_inventory/inventory.ttl> .
