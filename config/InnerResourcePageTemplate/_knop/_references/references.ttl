@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/InnerResourcePageTemplate> sflo:hasReferenceLink <config/InnerResourcePageTemplate/_knop/_references#reference001> .

<config/InnerResourcePageTemplate/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/InnerResourcePageTemplate> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
