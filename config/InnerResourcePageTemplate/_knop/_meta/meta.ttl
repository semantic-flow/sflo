@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/InnerResourcePageTemplate/_knop> a sflo:Knop ;
  sflo:designatorPath "config/InnerResourcePageTemplate" ;
  sflo:hasWorkingKnopInventoryFile <config/InnerResourcePageTemplate/_knop/_inventory/inventory.ttl> .
