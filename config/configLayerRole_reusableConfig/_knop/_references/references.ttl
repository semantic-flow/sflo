@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/configLayerRole_reusableConfig> sflo:hasReferenceLink <config/configLayerRole_reusableConfig/_knop/_references#reference001> .

<config/configLayerRole_reusableConfig/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/configLayerRole_reusableConfig> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
