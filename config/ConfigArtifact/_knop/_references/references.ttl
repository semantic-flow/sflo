@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ConfigArtifact> sflo:hasReferenceLink <config/ConfigArtifact/_knop/_references#reference001> .

<config/ConfigArtifact/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/ConfigArtifact> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
