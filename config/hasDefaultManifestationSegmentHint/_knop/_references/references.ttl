@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasDefaultManifestationSegmentHint> sflo:hasReferenceLink <config/hasDefaultManifestationSegmentHint/_knop/_references#reference001> .

<config/hasDefaultManifestationSegmentHint/_knop/_references#reference001> a sflo:ReferenceLink ;
  sflo:referenceLinkFor <config/hasDefaultManifestationSegmentHint> ;
  sflo:hasReferenceRole <https://semantic-flow.github.io/sflo/ontology/referenceRole_canonical> ;
  sflo:referenceTarget <config> .
