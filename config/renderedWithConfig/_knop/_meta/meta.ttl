@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/renderedWithConfig/_knop> a sflo:Knop ;
  sflo:designatorPath "config/renderedWithConfig" ;
  sflo:hasWorkingKnopInventoryFile <config/renderedWithConfig/_knop/_inventory/inventory.ttl> .
