@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasRemoteAccessRule/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasRemoteAccessRule" ;
  sflo:hasWorkingKnopInventoryFile <config/hasRemoteAccessRule/_knop/_inventory/inventory.ttl> .
