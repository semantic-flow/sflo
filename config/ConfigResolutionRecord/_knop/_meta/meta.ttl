@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/ConfigResolutionRecord/_knop> a sflo:Knop ;
  sflo:designatorPath "config/ConfigResolutionRecord" ;
  sflo:hasWorkingKnopInventoryFile <config/ConfigResolutionRecord/_knop/_inventory/inventory.ttl> .
