@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasConfigSourceFingerprint/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasConfigSourceFingerprint" ;
  sflo:hasWorkingKnopInventoryFile <config/hasConfigSourceFingerprint/_knop/_inventory/inventory.ttl> .
