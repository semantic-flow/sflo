@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasResourcePageGenerationPolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasResourcePageGenerationPolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/hasResourcePageGenerationPolicy/_knop/_inventory/inventory.ttl> .
