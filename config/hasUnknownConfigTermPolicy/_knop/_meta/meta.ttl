@base <https://semantic-flow.github.io/sflo/> .
@prefix sflo: <https://semantic-flow.github.io/sflo/ontology/> .

<config/hasUnknownConfigTermPolicy/_knop> a sflo:Knop ;
  sflo:designatorPath "config/hasUnknownConfigTermPolicy" ;
  sflo:hasWorkingKnopInventoryFile <config/hasUnknownConfigTermPolicy/_knop/_inventory/inventory.ttl> .
